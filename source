local function createTextInput(parent, opts)
    opts = opts or {}
    local text        = opts.Text or "Input"
    local default     = opts.Default or ""
    local placeholder = opts.Placeholder or "Type here..."
    local flag        = opts.Flag
    local callback    = opts.Callback

    local value = default

    local frame = Util.create("Frame", {
        Parent = parent,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 38),
    })

    Util.create("TextLabel", {
        Parent = frame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 16),
        Font = Fonts.Regular,
        Text = text,
        TextColor3 = Theme.TextWhite,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local input = Util.create("TextBox", {
        Parent = frame,
        BackgroundColor3 = Theme.ItemBg,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 18),
        Size = UDim2.new(1, 0, 0, 20),
        Font = Fonts.Mono,
        PlaceholderText = placeholder,
        PlaceholderColor3 = Theme.TextDark,
        Text = value,
        TextColor3 = Theme.TextWhite,
        TextSize = 11,
        ClearTextOnFocus = false,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    Util.corner(input, 3)
    Util.stroke(input, Theme.LineDark)
    Util.padding(input, 6, 6, 0, 0)

    input:GetPropertyChangedSignal("Text"):Connect(function()
        value = input.Text
    end)

    input.FocusLost:Connect(function()
        if callback then task.spawn(callback, value) end
    end)

    input.Focused:Connect(function()
        Util.tween(input:FindFirstChildOfClass("UIStroke"), { Color = Theme.Accent }, ANIM_SPEED_FAST)
    end)
    input.FocusLost:Connect(function()
        Util.tween(input:FindFirstChildOfClass("UIStroke"), { Color = Theme.LineDark }, ANIM_SPEED_FAST)
    end)

    if flag then
        Config:RegisterFlag(flag, function() return value end, function(val)
            value = tostring(val)
            input.Text = value
        end)
    end

    return {
        Frame = frame,
        GetValue = function() return value end,
        SetValue = function(v) value = v; input.Text = v end,
    }
end

