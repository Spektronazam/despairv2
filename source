local function createSidebar(parent, tabs, width)
    width = width or 120
    Util.line(parent, UDim2.new(0, width, 0, 0), UDim2.new(0, 1, 1, 0))

    local sidebar = Util.create("Frame", {
        Parent = parent,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, width, 1, 0),
    })

    local contentArea = Util.create("Frame", {
        Parent = parent,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, width + 1, 0, 0),
        Size = UDim2.new(1, -(width + 1), 1, 0),
        ClipsDescendants = true,
    })

    local sidebarTabs = {}
    local activeSideTab = nil

    local function switchSideTab(name)
        if activeSideTab == name then return end
        for n, t in pairs(sidebarTabs) do
            local active = (n == name)
            t.page.Visible = active
            Util.tween(t.label, { TextColor3 = active and Theme.TextWhite or Theme.TextGray }, ANIM_SPEED_FAST)
            t.bar.Visible = active
        end
        activeSideTab = name
    end

    for i, tabInfo in ipairs(tabs) do
        local name = tabInfo.Name or tabInfo
        local isDefault = (i == 1)
        local yPos = (i - 1) * 34 + 10

        local btn = Util.create("TextButton", {
            Parent = sidebar,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 0, 0, yPos),
            Size = UDim2.new(1, 0, 0, 30),
            Text = "",
            AutoButtonColor = false,
        })

        local label = Util.create("TextLabel", {
            Parent = btn,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 18, 0, 0),
            Size = UDim2.new(1, -18, 1, 0),
            Font = Fonts.Regular,
            Text = name,
            TextColor3 = isDefault and Theme.TextWhite or Theme.TextGray,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
        })

        local bar = Util.create("Frame", {
            Parent = btn,
            BackgroundColor3 = Theme.Accent,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 2, 0, 6),
            Size = UDim2.new(0, 2, 0, 18),
            Visible = isDefault,
        })
        Util.corner(bar, 1)

        local page = Util.create("ScrollingFrame", {
            Parent = contentArea,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            ScrollBarThickness = 0,
            BorderSizePixel = 0,
            Visible = isDefault,
            CanvasSize = UDim2.new(0, 0, 0, 0),
        })

        sidebarTabs[name] = { label = label, bar = bar, page = page }

        btn.MouseButton1Click:Connect(function() switchSideTab(name) end)
        btn.MouseEnter:Connect(function()
            if activeSideTab ~= name then
                Util.tween(label, { TextColor3 = Theme.TextWhite }, ANIM_SPEED_FAST)
            end
        end)
        btn.MouseLeave:Connect(function()
            if activeSideTab ~= name then
                Util.tween(label, { TextColor3 = Theme.TextGray }, ANIM_SPEED_FAST)
            end
        end)

        if isDefault then activeSideTab = name end
    end

    return sidebarTabs, contentArea
end

