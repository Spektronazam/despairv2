local ioPage = configSideTabs["Import / Export"].page
local pnlIO = createPanel(ioPage, "Import / Export", UDim2.new(0, 10, 0, 10), UDim2.new(0, 300, 0, 200))

createButton(pnlIO, { Text = "Export to Clipboard", Callback = function()
    local data = {}
    for flag, funcs in pairs(Config._flags) do
        local ok, val = pcall(funcs.get)
        if ok then
            if typeof(val) == "Color3" then
                data[flag] = { _type = "Color3", r = val.R, g = val.G, b = val.B }
            else
                data[flag] = val
            end
        end
    end
    local ok, json = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then
        pcall(setclipboard, json)
        Notifications:Send({ Title = "Exported", Message = "Config copied to clipboard.", Type = "Success", Duration = 3 })
    end
end })

local importInput = createTextInput(pnlIO, { Text = "Import Data", Placeholder = "Paste JSON config here..." })

createButton(pnlIO, { Text = "Import from Text", Callback = function()
    local raw = importInput.GetValue()
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok or type(data) ~= "table" then
        Notifications:Send({ Title = "Error", Message = "Invalid JSON data.", Type = "Error", Duration = 3 })
        return
    end
    for flag, val in pairs(data) do
        if type(val) == "table" and val._type == "Color3" then
            val = Color3.new(val.r, val.g, val.b)
        end
        if Config._flags[flag] then
            pcall(Config._flags[flag].set, val)
        end
    end
    Notifications:Send({ Title = "Imported", Message = "Config applied from text.", Type = "Success", Duration = 3 })
end })

