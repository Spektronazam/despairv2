------------------------------ Helpers ------------------------------

local function create(className: string, props: { [string]: any }): Instance
	local inst = Instance.new(className)
	for key, value in props do
		(inst :: any)[key] = value
	end
	return inst
end

local function tween(obj: Instance, props: { [string]: any }, duration: number?)
	local info = TweenInfo.new(duration or cfg.tweenDuration, cfg.ease, Enum.EasingDirection.Out)
	TweenService:Create(obj, info, props):Play()
end

local function addCorner(parent: GuiObject, radius: number?): UICorner
	return create("UICorner", {
		Parent = parent,
		CornerRadius = UDim.new(0, radius or 4),
	}) :: UICorner
end

local function addStroke(parent: GuiObject, color: Color3?, thickness: number?): UIStroke
	return create("UIStroke", {
		Parent = parent,
		Color = color or pal.border,
		Thickness = thickness or 1,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
	}) :: UIStroke
end

local function bindHover(maid: Maid, obj: GuiObject, base: Color3, hov: Color3, act: Color3?)
	maid:Add(obj.MouseEnter:Connect(function()
		tween(obj, { BackgroundColor3 = hov })
	end))
	maid:Add(obj.MouseLeave:Connect(function()
		tween(obj, { BackgroundColor3 = base })
	end))
	if act then
		maid:Add((obj :: any).MouseButton1Down:Connect(function()
			tween(obj, { BackgroundColor3 = act }, 0.06)
		end))
		maid:Add((obj :: any).MouseButton1Up:Connect(function()
			tween(obj, { BackgroundColor3 = hov }, 0.08)
		end))
	end
end

local function makeDraggable(maid: Maid, grip: GuiObject, frame: GuiObject)
	local dragging = false
	local dragInput: InputObject? = nil
	local dragStart: Vector3
	local startPos: UDim2

	maid:Add(grip.InputBegan:Connect(function(input: InputObject)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
	end))

	maid:Add(grip.InputChanged:Connect(function(input: InputObject)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end))

	maid:Add(UserInputService.InputChanged:Connect(function(input: InputObject)
		if not dragging or input ~= dragInput then return end
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end))

	maid:Add(UserInputService.InputEnded:Connect(function(input: InputObject)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
			dragInput = nil
		end
	end))
end

local function formatNumber(value: number): string
	if value % 1 == 0 then
		return string.format("%d", value)
	end
	return (string.format("%.4f", value):gsub("0+$", ""):gsub("%.$", ""))
end

local function sanitizeString(input: string, maxLength: number?): string
	return input:sub(1, maxLength or cfg.maxInputLength)
end

local function sanitizeNumber(input: string, mn: number, mx: number, fallback: number): number
	local n = tonumber(input)
	if not n or n ~= n then return fallback end
	return math.clamp(n, mn, mx)
end

local function sanitizeHex(input: string): string?
	local hex = input:gsub("#", ""):upper()
	if #hex ~= 6 or hex:match("[^%dA-F]") then return nil end
	return `#{hex}`
end

