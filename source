local ioPage = cfgSideTabs["Import/Export"].page
local pIO = panel(ioPage, "Import / Export", UDim2.new(0,10,0,10), UDim2.new(0,300,0,200))

wButton(pIO, { Text = "Export to Clipboard", Callback = function()
    local data = {}
    for flag, fns in pairs(Config._flags) do
        local ok, val = pcall(fns.get)
        if ok then
            if typeof(val) == "Color3" then data[flag] = {_t="c3",r=val.R,g=val.G,b=val.B} else data[flag] = val end
        end
    end
    pcall(function() setclipboard(HTTP:JSONEncode(data)) end)
    Notify:Send({ Title = "Exported", Message = "Copied to clipboard.", Type = "Success", Duration = 3 })
end })

local importInput = wInput(pIO, { Text = "Import Data", Placeholder = "Paste JSON..." })
wButton(pIO, { Text = "Import from Text", Callback = function()
    local ok, data = pcall(HTTP.JSONDecode, HTTP, importInput.Get())
    if not ok or type(data) ~= "table" then Notify:Send({ Title = "Error", Message = "Bad JSON.", Type = "Error" }) return end
    for flag, val in pairs(data) do
        if type(val)=="table" and val._t=="c3" then val = Color3.new(val.r,val.g,val.b) end
        if Config._flags[flag] then pcall(Config._flags[flag].set, val) end
    end
    Notify:Send({ Title = "Imported", Message = "Config applied.", Type = "Success", Duration = 3 })
end })

