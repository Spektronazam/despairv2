-- UTILITY
----------------------------------------------------------------
local U = {}

function U.new(c, p)
    local i = Instance.new(c)
    for k, v in pairs(p) do
        if k ~= "Parent" then i[k] = v end
    end
    if p.Parent then i.Parent = p.Parent end
    return i
end

function U.tween(obj, props, dur, style, dir)
    local tw = TS:Create(obj, TweenInfo.new(dur or SP_TIME, style or SP_STYLE, dir or SP_DIR), props)
    tw:Play()
    return tw
end

function U.tweenFast(obj, props)
    return U.tween(obj, props, FAST, FAST_STYLE, FAST_DIR)
end

function U.corner(p, r)
    return U.new("UICorner", { Parent = p, CornerRadius = UDim.new(0, r or 6) })
end

function U.stroke(p, c, t)
    return U.new("UIStroke", { Parent = p, Color = c or T.Line, Thickness = t or 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border })
end

function U.pad(p, l, r, t, b)
    return U.new("UIPadding", { Parent = p, PaddingLeft = UDim.new(0,l or 0), PaddingRight = UDim.new(0,r or 0), PaddingTop = UDim.new(0,t or 0), PaddingBottom = UDim.new(0,b or 0) })
end

function U.list(p, gap, dir)
    return U.new("UIListLayout", { Parent = p, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, gap or 4), FillDirection = dir or Enum.FillDirection.Vertical })
end

function U.line(p, pos, size)
    return U.new("Frame", { Parent = p, BackgroundColor3 = T.Line, BorderSizePixel = 0, Position = pos, Size = size })
end

function U.icon(p, key, size, color, pos)
    return U.new("ImageLabel", {
        Parent = p,
        BackgroundTransparency = 1,
        Image = Icons[key] or "",
