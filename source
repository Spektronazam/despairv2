            task.delay(0.2, function()
                local outsideConn
                outsideConn = UIS.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        task.defer(function()
                            if popup and popup.Parent then
