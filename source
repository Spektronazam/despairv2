------------------------------ Config Manager (sUNC Filesystem) ----------------------------

local ConfigManager = {}

function ConfigManager.Save(name: string): boolean
	if not writefile then
		warn("[Despair] Config saving requires 'writefile' (sUNC filesystem)")
		return false
	end
	ensureConfigDir()

	local data: { [string]: any } = {}
	for key, value in flags do
		local t = typeof(value)
		if t == "boolean" or t == "number" or t == "string" then
			data[key] = { type = t, value = value }
		elseif t == "Color3" then
			data[key] = { type = "Color3", value = (value :: Color3):ToHex() }
		elseif t == "EnumItem" then
			data[key] = { type = "KeyCode", value = (value :: Enum.KeyCode).Name }
		end
	end

	local ok, err = pcall(function()
		writefile(configPath(name), HttpService:JSONEncode(data))
	end)
	if not ok then
		warn(`[Despair] Config save failed: {err}`)
		return false
	end
	return true
end

function ConfigManager.Load(name: string): boolean
	if not readfile or not isfile then
		warn("[Despair] Config loading requires 'readfile'/'isfile' (sUNC filesystem)")
		return false
	end

	local path = configPath(name)
	if not isfile(path) then
		warn(`[Despair] Config file not found: {path}`)
		return false
	end

	local ok, result = pcall(function()
		return HttpService:JSONDecode(readfile(path))
	end)
	if not ok or not result then
		warn(`[Despair] Config load failed: {result}`)
		return false
	end

	for key, entry in result :: { [string]: any } do
		if type(entry) ~= "table" then continue end
		local t, v = entry.type, entry.value
		if t == "boolean" and type(v) == "boolean" then
			flags[key] = v
		elseif t == "number" and type(v) == "number" then
			flags[key] = v
		elseif t == "string" and type(v) == "string" then
			flags[key] = v
		elseif t == "Color3" and type(v) == "string" then
			local success, col = pcall(Color3.fromHex, v)
			if success then flags[key] = col end
		elseif t == "KeyCode" and type(v) == "string" then
			local success, kc = pcall(function() return (Enum.KeyCode :: any)[v] end)
			if success then flags[key] = kc end
		end
	end
	return true
end

function ConfigManager.Delete(name: string): boolean
	if not delfile or not isfile then
		warn("[Despair] Config deletion requires 'delfile'/'isfile' (sUNC filesystem)")
		return false
	end

	local path = configPath(name)
	if not isfile(path) then return false end

	local ok, err = pcall(delfile, path)
	if not ok then
		warn(`[Despair] Config delete failed: {err}`)
		return false
	end
	return true
end

function ConfigManager.List(): { string }
	if not listfiles or not isfolder or not isfolder(CONFIG_DIR) then
		return {}
	end

	local files: { string } = {}
	local ok, result = pcall(listfiles, CONFIG_DIR)
	if not ok or not result then return {} end

	for _, path in result do
		local name = path:match("([^/\\]+)%.json$")
		if name then
			table.insert(files, name)
		end
	end
	return files
end

