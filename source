local function makeResizable(frame, minW, minH)
    minW = minW or 600
    minH = minH or 400

    local handle = Util.create("TextButton", {
        Parent = frame,
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -15, 1, -15),
        Size = UDim2.new(0, 15, 0, 15),
        Text = "",
        AutoButtonColor = false,
        ZIndex = 50,
    })

    -- Diagonal resize grip dots
    for i = 0, 2 do
        for j = 0, i do
            Util.create("Frame", {
                Parent = handle,
                BackgroundColor3 = Theme.TextDark,
                BorderSizePixel = 0,
                Position = UDim2.new(1, -4 - (i * 4), 1, -4 - (j * 4)),
                Size = UDim2.new(0, 2, 0, 2),
                ZIndex = 50,
            })
        end
    end

    local resizing = false
    local resizeStart, startSize

    handle.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        resizing = true
        resizeStart = input.Position
        startSize = frame.Size
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                resizing = false
            end
        end)
    end)

    UIS.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - resizeStart
            local newW = math.max(minW, startSize.X.Offset + delta.X)
            local newH = math.max(minH, startSize.Y.Offset + delta.Y)
            frame.Size = UDim2.new(0, newW, 0, newH)
        end
    end)
end

