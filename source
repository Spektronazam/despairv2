local function refreshProfileList()
    for _, c in ipairs(profileListContainer:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local profiles = Config:ListProfiles()
    if #profiles == 0 then
        Util.create("TextButton", {
            Parent = profileListContainer,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 20),
            Font = Fonts.Regular,
            Text = "No profiles saved yet.",
            TextColor3 = Theme.TextDark,
            TextSize = 10,
            AutoButtonColor = false,
        })
    else
        for _, name in ipairs(profiles) do
            local pBtn = Util.create("TextButton", {
                Parent = profileListContainer,
                BackgroundColor3 = Theme.ItemBg,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 22),
                Font = Fonts.Regular,
                Text = "  " .. name .. (name == Config._profile and " (active)" or ""),
                TextColor3 = name == Config._profile and Theme.Accent or Theme.TextGray,
                TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Left,
                AutoButtonColor = false,
            })
            Util.corner(pBtn, 3)

            pBtn.MouseButton1Click:Connect(function()
                profileInput.SetValue(name)
            end)
            pBtn.MouseEnter:Connect(function()
                Util.tween(pBtn, { BackgroundColor3 = Theme.ItemBgHover }, ANIM_SPEED_FAST)
            end)
            pBtn.MouseLeave:Connect(function()
                Util.tween(pBtn, { BackgroundColor3 = Theme.ItemBg }, ANIM_SPEED_FAST)
            end)

            -- Right click context menu
            pBtn.MouseButton2Click:Connect(function()
                ContextMenu:Show(UIS:GetMouseLocation(), {
                    { Text = "Load", Callback = function()
                        Config:Load(name)
                        Notifications:Send({ Title = "Loaded", Message = name, Type = "Success", Duration = 2 })
                    end },
                    { Text = "Set Active", Callback = function()
                        Config._profile = name
                        refreshProfileList()
                    end },
                    { Separator = true },
                    { Text = "Delete", Color = Theme.Error, Callback = function()
                        Config:DeleteProfile(name)
                        refreshProfileList()
                        Notifications:Send({ Title = "Deleted", Message = name, Type = "Info", Duration = 2 })
                    end },
                })
            end)
        end
    end
end

