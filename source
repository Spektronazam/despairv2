    end)

    if tooltip then
        Tooltip:Bind(hitBtn, tooltip)
    end

    -- Config flag
    if flag then
        Config:RegisterFlag(flag, function() return state end, function(val)
            setState(val, true)
        end)
    end

    -- Color flag
    if flag and colorPick then
        Config:RegisterFlag(flag .. "_color", function() return colorState end, function(val)
            colorState = val
            if colorFrame then colorFrame.BackgroundColor3 = val end
        end)
    end

    return {
        Frame = frame,
        SetState = setState,
        GetState = function() return state end,
        OnChanged = Signal.new(),
        ColorChanged = colorSignal,
    }
end

