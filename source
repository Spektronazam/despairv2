			addStroke(hueMark, Color3.new(0, 0, 0), 1)

			local preview = create("Frame", {
				Parent = pickerWrap, BackgroundColor3 = col,
				Position = UDim2.new(1, -34, 0, 8),
				Size = UDim2.new(0, 18, 0, 100),
