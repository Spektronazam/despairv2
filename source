            Position = UDim2.new(0, 2, 0, 5), Size = UDim2.new(0, 2, 0, 18), Visible = isDef,
        })
        U.corner(bar, 1)

        local page = U.new("ScrollingFrame", {
            Parent = content, BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0),
            ScrollBarThickness = 0, BorderSizePixel = 0, Visible = isDef, CanvasSize = UDim2.new(0,0,0,0),
        })

        sTabs[tabName] = { lbl = lbl, bar = bar, page = page }
        btn.MouseButton1Click:Connect(function() switchSide(tabName) end)
        btn.MouseEnter:Connect(function()
            if activeSide ~= tabName then U.tweenFast(lbl, { TextColor3 = T.White }) end
        end)
        btn.MouseLeave:Connect(function()
            if activeSide ~= tabName then U.tweenFast(lbl, { TextColor3 = T.Gray }) end
        end)
        if isDef then activeSide = tabName end
    end

    return sTabs, content
end

