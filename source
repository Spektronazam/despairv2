----------------------------------------------------------------
-- OPEN ANIMATION — Staggered cascade reveal
----------------------------------------------------------------
do
    Main.Size = UDim2.new(0, 880, 0, 0)
    Main.BackgroundTransparency = 0.5

    task.defer(function()
        -- Window expand (spring overshoot)
        U.tween(Main, { Size = UDim2.new(0, 880, 0, 560), BackgroundTransparency = 0 }, 0.5, Enum.EasingStyle.Back)
        task.wait(0.2)

        -- Stagger panels in
        local allPanels = {}
        for _, desc in ipairs(Body:GetDescendants()) do
            if desc:IsA("Frame") and desc.BackgroundColor3 == T.Panel and desc.Parent and desc.Parent:IsA("ScrollingFrame") == false then
                table.insert(allPanels, desc)
            end
        end

        for i, p in ipairs(allPanels) do
            if p and p.Parent then
                local origPos = p.Position
                p.Position = UDim2.new(origPos.X.Scale, origPos.X.Offset, origPos.Y.Scale, origPos.Y.Offset + 30)
                p.BackgroundTransparency = 1

                task.delay(i * 0.06, function()
                    if p and p.Parent then
                        U.tween(p, { Position = origPos, BackgroundTransparency = 0 }, 0.4, Enum.EasingStyle.Back)
                    end
                end)
            end
        end

        -- Re-apply tab states
        switchBtm(activeBtm)
    end)
end

