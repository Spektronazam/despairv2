local function createKeybind(parent, opts)
    opts = opts or {}
    local text     = opts.Text or "Keybind"
    local default  = opts.Default -- EnumItem or nil
    local flag     = opts.Flag
    local callback = opts.Callback  -- fires when key pressed in-game
    local mode     = opts.Mode or "Toggle" -- Toggle, Hold, Always

    local bound = default
    local listening = false
    local active = false

    local frame = Util.create("Frame", {
        Parent = parent,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 18),
    })

    Util.create("TextLabel", {
        Parent = frame,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.6, 0, 1, 0),
        Font = Fonts.Regular,
        Text = text,
        TextColor3 = Theme.TextGray,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local bindBtn = Util.create("TextButton", {
        Parent = frame,
        BackgroundColor3 = Theme.ItemBg,
        BorderSizePixel = 0,
        Position = UDim2.new(0.6, 4, 0.5, -8),
        Size = UDim2.new(0.4, -4, 0, 16),
        Font = Fonts.Mono,
        Text = bound and ("[ " .. Util.keyName(bound) .. " ]") or "[ None ]",
        TextColor3 = Theme.TextGray,
        TextSize = 10,
        AutoButtonColor = false,
    })
    Util.corner(bindBtn, 3)

    bindBtn.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true
        bindBtn.Text = "[ ... ]"
        bindBtn.TextColor3 = Theme.Accent

        local conn
        conn = UIS.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Keyboard then
                if input.KeyCode == Enum.KeyCode.Escape then
                    bound = nil
                    bindBtn.Text = "[ None ]"
                else
                    bound = input.KeyCode
                    bindBtn.Text = "[ " .. Util.keyName(bound) .. " ]"
                end
                bindBtn.TextColor3 = Theme.TextGray
                listening = false
                conn:Disconnect()
            end
        end)
    end)

    -- Right click to clear
    bindBtn.MouseButton2Click:Connect(function()
        bound = nil
        bindBtn.Text = "[ None ]"
    end)

    -- Runtime keybind listener
    UIS.InputBegan:Connect(function(input, processed)
        if processed or listening then return end
        if bound and input.KeyCode == bound then
            if mode == "Toggle" then
                active = not active
                if callback then task.spawn(callback, active) end
            elseif mode == "Hold" then
                active = true
                if callback then task.spawn(callback, true) end
            end
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if bound and input.KeyCode == bound and mode == "Hold" then
            active = false
            if callback then task.spawn(callback, false) end
        end
    end)

    if flag then
        Config:RegisterFlag(flag, function()
            return bound and bound.Name or nil
        end, function(val)
            if val and typeof(val) == "string" then
                pcall(function()
                    bound = Enum.KeyCode[val]
                    bindBtn.Text = "[ " .. Util.keyName(bound) .. " ]"
                end)
            else
                bound = nil
                bindBtn.Text = "[ None ]"
            end
        end)
    end

    return {
        Frame = frame,
        GetKey = function() return bound end,
        IsActive = function() return active end,
    }
end

