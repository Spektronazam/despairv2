-- CONFIG MANAGER
----------------------------------------------------------------
local Config = {}
Config._data = {}
Config._flags = {}  -- flagName -> {get, set} for widgets
Config._profile = DEFAULT_PROFILE
Config.OnChanged = Signal.new()

function Config:_ensureFolders()
    local ok, _ = pcall(function()
        if not isfolder(CONFIG_FOLDER) then
            makefolder(CONFIG_FOLDER)
        end
        if not isfolder(PROFILES_FOLDER) then
            makefolder(PROFILES_FOLDER)
        end
    end)
    return ok
end

function Config:_filePath(profile)
    return PROFILES_FOLDER .. "/" .. (profile or self._profile) .. ".json"
end

function Config:Save(profile)
    if not self:_ensureFolders() then
        warn("[Despair] File system not available — config not saved")
        return false
    end

    local data = {}
    for flag, funcs in pairs(self._flags) do
        local ok, val = pcall(funcs.get)
        if ok then
            if typeof(val) == "Color3" then
                data[flag] = { _type = "Color3", r = val.R, g = val.G, b = val.B }
            elseif typeof(val) == "EnumItem" then
                data[flag] = { _type = "EnumItem", enum = tostring(val.EnumType), name = val.Name }
            else
                data[flag] = val
            end
        end
    end

    local ok, json = pcall(HttpService.JSONEncode, HttpService, data)
    if not ok then
        warn("[Despair] JSON encode failed: " .. tostring(json))
        return false
    end

    local ok2, err = pcall(writefile, self:_filePath(profile), json)
    if not ok2 then
        warn("[Despair] Write failed: " .. tostring(err))
        return false
    end
    return true
end

function Config:Load(profile)
    if not self:_ensureFolders() then return false end

    local path = self:_filePath(profile)
    local ok, exists = pcall(isfile, path)
    if not ok or not exists then return false end

    local ok2, raw = pcall(readfile, path)
    if not ok2 then return false end

    local ok3, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok3 or type(data) ~= "table" then return false end

    for flag, val in pairs(data) do
        if type(val) == "table" and val._type == "Color3" then
            val = Color3.new(val.r, val.g, val.b)
        elseif type(val) == "table" and val._type == "EnumItem" then
            pcall(function()
                val = Enum[val.enum][val.name]
            end)
        end
        if self._flags[flag] then
            pcall(self._flags[flag].set, val)
        end
    end
    self._profile = profile or self._profile
    self.OnChanged:Fire()
    return true
end

function Config:ListProfiles()
    local profiles = {}
    pcall(function()
        if isfolder(PROFILES_FOLDER) then
            for _, file in ipairs(listfiles(PROFILES_FOLDER)) do
                local name = file:match("([^/\\]+)%.json$")
                if name then
                    table.insert(profiles, name)
                end
            end
        end
    end)
    return profiles
end

function Config:DeleteProfile(profile)
    pcall(function()
        local path = self:_filePath(profile)
        if isfile(path) then
            delfile(path)
        end
    end)
end

function Config:RegisterFlag(name, getFn, setFn)
    self._flags[name] = { get = getFn, set = setFn }
end

