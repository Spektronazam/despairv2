        if stroke then stroke.Color = state and Theme.Accent or Theme.LineDark end
        checkMark.Text = state and "✓" or ""
        Util.tween(label, { TextColor3 = state and Theme.TextWhite or Theme.TextGray }, ANIM_SPEED_FAST)
        if not skipCallback and callback then
