local function createDropdown(parent, opts)
    opts = opts or {}
    local text     = opts.Text or "Dropdown"
    local options  = opts.Options or {}
    local default  = opts.Default or (options[1] or "")
    local multi    = opts.Multi or false
    local flag     = opts.Flag
    local callback = opts.Callback

    local selected = multi and (type(default) == "table" and default or {}) or default
    local opened = false

    local frame = Util.create("Frame", {
        Parent = parent,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 38),
        ClipsDescendants = false,
    })

    Util.create("TextLabel", {
        Parent = frame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 16),
        Font = Fonts.Regular,
        Text = text,
        TextColor3 = Theme.TextWhite,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local dropBtn = Util.create("TextButton", {
        Parent = frame,
        BackgroundColor3 = Theme.ItemBg,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 18),
        Size = UDim2.new(1, 0, 0, 20),
        Font = Fonts.Regular,
        Text = "",
        AutoButtonColor = false,
    })
    Util.corner(dropBtn, 3)
    Util.stroke(dropBtn, Theme.LineDark)

    local function getDisplayText()
        if multi then
            if #selected == 0 then return "None" end
            return table.concat(selected, ", ")
        else
            return tostring(selected)
        end
    end

    local selectedLabel = Util.create("TextLabel", {
        Parent = dropBtn,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 0),
        Size = UDim2.new(1, -28, 1, 0),
        Font = Fonts.Regular,
        Text = getDisplayText(),
        TextColor3 = Theme.TextGray,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
    })

    local arrow = Util.create("TextLabel", {
        Parent = dropBtn,
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -18, 0, 0),
        Size = UDim2.new(0, 14, 1, 0),
        Font = Fonts.Regular,
        Text = "▼",
        TextColor3 = Theme.TextDark,
        TextSize = 9,
    })

    local optionsContainer = Util.create("Frame", {
        Parent = frame,
        BackgroundColor3 = Theme.ItemBg,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 40),
        Size = UDim2.new(1, 0, 0, 0),
        ClipsDescendants = true,
        ZIndex = 70,
        Visible = false,
    })
    Util.corner(optionsContainer, 3)
    Util.stroke(optionsContainer, Theme.LineColor)

    local optList = Util.create("ScrollingFrame", {
        Parent = optionsContainer,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = Theme.ScrollBar,
        BorderSizePixel = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ZIndex = 71,
    })
    local optLayout = Util.listLayout(optList, 1)
    optLayout.ZIndex = 71

    local function refreshOptions()
        for _, c in ipairs(optList:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end

        for i, opt in ipairs(options) do
            local isSelected = multi and table.find(selected, opt) or (selected == opt)

            local optBtn = Util.create("TextButton", {
                Parent = optList,
                BackgroundColor3 = isSelected and Theme.AccentDark or Theme.ItemBg,
                BackgroundTransparency = isSelected and 0.5 or 1,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 22),
                Font = Fonts.Regular,
                Text = "",
                AutoButtonColor = false,
                LayoutOrder = i,
                ZIndex = 72,
            })

            Util.create("TextLabel", {
                Parent = optBtn,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 8, 0, 0),
                Size = UDim2.new(1, -16, 1, 0),
                Font = Fonts.Regular,
                Text = opt,
                TextColor3 = isSelected and Theme.TextWhite or Theme.TextGray,
                TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 72,
            })

            optBtn.MouseEnter:Connect(function()
                Util.tween(optBtn, { BackgroundTransparency = 0.3, BackgroundColor3 = Theme.ItemBgHover }, ANIM_SPEED_FAST)
            end)
            optBtn.MouseLeave:Connect(function()
                local sel = multi and table.find(selected, opt) or (selected == opt)
                Util.tween(optBtn, {
                    BackgroundTransparency = sel and 0.5 or 1,
                    BackgroundColor3 = sel and Theme.AccentDark or Theme.ItemBg,
                }, ANIM_SPEED_FAST)
            end)

            optBtn.MouseButton1Click:Connect(function()
                if multi then
                    local idx = table.find(selected, opt)
                    if idx then
                        table.remove(selected, idx)
                    else
                        table.insert(selected, opt)
                    end
                    selectedLabel.Text = getDisplayText()
                    refreshOptions()
                    if callback then task.spawn(callback, selected) end
                else
                    selected = opt
                    selectedLabel.Text = getDisplayText()
                    refreshOptions()
                    -- Close
                    opened = false
                    optionsContainer.Visible = false
                    Util.tween(optionsContainer, { Size = UDim2.new(1, 0, 0, 0) }, ANIM_SPEED_FAST)
                    arrow.Text = "▼"
                    frame.Size = UDim2.new(1, 0, 0, 38)
                    if callback then task.spawn(callback, selected) end
                end
            end)
        end

        optList.CanvasSize = UDim2.new(0, 0, 0, optLayout.AbsoluteContentSize.Y + 4)
    end

    refreshOptions()

    dropBtn.MouseButton1Click:Connect(function()
        opened = not opened
        if opened then
            local totalHeight = math.min(#options * 23 + 4, 150)
            optionsContainer.Visible = true
            Util.tween(optionsContainer, { Size = UDim2.new(1, 0, 0, totalHeight) }, ANIM_SPEED)
            arrow.Text = "▲"
            frame.Size = UDim2.new(1, 0, 0, 40 + totalHeight + 2)
        else
            Util.tween(optionsContainer, { Size = UDim2.new(1, 0, 0, 0) }, ANIM_SPEED)
            task.delay(ANIM_SPEED, function()
                if not opened then optionsContainer.Visible = false end
            end)
            arrow.Text = "▼"
            frame.Size = UDim2.new(1, 0, 0, 38)
        end
    end)

    dropBtn.MouseEnter:Connect(function()
        Util.tween(dropBtn, { BackgroundColor3 = Theme.ItemBgHover }, ANIM_SPEED_FAST)
    end)
    dropBtn.MouseLeave:Connect(function()
        Util.tween(dropBtn, { BackgroundColor3 = Theme.ItemBg }, ANIM_SPEED_FAST)
    end)

    if flag then
        Config:RegisterFlag(flag, function() return selected end, function(val)
            selected = val
            selectedLabel.Text = getDisplayText()
            refreshOptions()
        end)
    end

    return {
        Frame = frame,
        GetSelected = function() return selected end,
        SetOptions = function(newOpts)
            options = newOpts
            refreshOptions()
        end,
        Refresh = refreshOptions,
    }
end

