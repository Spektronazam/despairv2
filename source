			}) :: Frame
			addCorner(preview, 4)
			addStroke(preview, pal.border, 1)

			local h, s, v = col:ToHSV()

			local function flush()
				col = Color3.fromHSV(h, s, v)
				svBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
				swatch.BackgroundColor3 = col
				preview.BackgroundColor3 = col
				hexBox.Text = `#{col:ToHex():upper()}`
				svMark.Position = UDim2.new(s, 0, 1 - v, 0)
				hueMark.Position = UDim2.new(0, 0, h, 0)
				setFlag(flag, col)
				safeCall(cb, col)
			end
			flush()

			local pullSV, pullH = false, false

			windowMaid:Add(svBox.InputBegan:Connect(function(i)
				if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
				pullSV = true
				s = math.clamp((i.Position.X - svBox.AbsolutePosition.X) / svBox.AbsoluteSize.X, 0, 1)
				v = 1 - math.clamp((i.Position.Y - svBox.AbsolutePosition.Y) / svBox.AbsoluteSize.Y, 0, 1)
				flush()
			end))

			windowMaid:Add(hueStrip.InputBegan:Connect(function(i)
				if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
				pullH = true
				h = math.clamp((i.Position.Y - hueStrip.AbsolutePosition.Y) / hueStrip.AbsoluteSize.Y, 0, 1)
				flush()
			end))

			windowMaid:Add(UserInputService.InputChanged:Connect(function(i)
				if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
				if pullSV then
					s = math.clamp((i.Position.X - svBox.AbsolutePosition.X) / svBox.AbsoluteSize.X, 0, 1)
					v = 1 - math.clamp((i.Position.Y - svBox.AbsolutePosition.Y) / svBox.AbsoluteSize.Y, 0, 1)
					flush()
				end
				if pullH then
					h = math.clamp((i.Position.Y - hueStrip.AbsolutePosition.Y) / hueStrip.AbsoluteSize.Y, 0, 1)
					flush()
				end
			end))

			windowMaid:Add(UserInputService.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 then
					pullSV = false
					pullH = false
				end
			end))

			windowMaid:Add(hexBox.FocusLost:Connect(function()
				local sanitized = sanitizeHex(hexBox.Text)
				if not sanitized then
					hexBox.Text = `#{col:ToHex():upper()}`
					return
				end
				local ok, nc = pcall(Color3.fromHex, sanitized)
				if ok and nc then
					h, s, v = nc:ToHSV()
					flush()
				else
					hexBox.Text = `#{col:ToHex():upper()}`
				end
			end))

			local pkH = cfg.pickerHeight

			windowMaid:Add(swatch.MouseButton1Click:Connect(function()
				if destroying then return end
				expanded = not expanded
				if expanded then
					fo._items += pkH / cfg.rowHeight
					tween(row, { Size = UDim2.new(1, 0, 0, cfg.rowHeight + pkH) }, 0.22)
					tween(pickerWrap, { Size = UDim2.new(1, 0, 0, pkH) }, 0.22)
				else
					fo._items -= pkH / cfg.rowHeight
					tween(row, { Size = UDim2.new(1, 0, 0, cfg.rowHeight) }, 0.22)
					tween(pickerWrap, { Size = UDim2.new(1, 0, 0, 0) }, 0.22)
				end
				recalc()
			end))

			local api = {} :: ElementAPI<Color3>
			function api:Set(c: Color3)
				h, s, v = c:ToHSV()
				flush()
			end
			function api:Get(): Color3
				return col
			end
			setFlag(flag, col)
			return api
		end

		function fo:Dropdown(opts: DropdownOpts): ElementAPI<string>
			local label = opts.name or opts.text or "Select"
			local lo = nxt()
			local pool: { string } = opts.items or opts.options or {}
			local sel: string = opts.default or pool[1] or ""
			local cb = opts.callback or opts.cb
			local flag: string? = opts.flag
			local dropped = false

			if #pool > 0 and not table.find(pool, sel) then
				sel = pool[1]
			end

			local row, ctrl = baseRow(container, label, lo)

			local face = create("TextButton", {
				Parent = ctrl, BackgroundColor3 = pal.control,
				Position = UDim2.new(0, 6, 0.5, -8),
				Size = UDim2.new(1, -12, 0, 16),
				Text = `{sel}  ▾`, TextColor3 = pal.text,
				Font = cfg.font, TextSize = cfg.textSize,
				AutoButtonColor = false, BorderSizePixel = 0,
			}) :: TextButton
			addCorner(face, 3)
			bindHover(windowMaid, face, pal.control, pal.controlHov, pal.controlAct)

			local dropWrap = create("Frame", {
				Parent = row, BackgroundColor3 = pal.elevated,
				Position = UDim2.new(0.38, 2, 0, cfg.rowHeight),
				Size = UDim2.new(0.62, -2, 0, 0),
				ClipsDescendants = true, BorderSizePixel = 0, ZIndex = 12,
			}) :: Frame
			addCorner(dropWrap, 4)
			addStroke(dropWrap, pal.accent, 1)
			create("UIListLayout", {
				Parent = dropWrap, SortOrder = Enum.SortOrder.LayoutOrder,
				Padding = UDim.new(0, 1),
			})

			local dh = #pool * cfg.dropdownItemH

			local function closeDropdown()
				if not dropped then return end
				dropped = false
				fo._items -= dh / cfg.rowHeight
				tween(row, { Size = UDim2.new(1, 0, 0, cfg.rowHeight) }, 0.18)
				tween(dropWrap, { Size = UDim2.new(0.62, -2, 0, 0) }, 0.18)
				recalc()
			end

			for idx, item in pool do
				local sanitizedItem = sanitizeString(tostring(item), 100)
				local opt = create("TextButton", {
					Parent = dropWrap, BackgroundColor3 = pal.elevated,
					Size = UDim2.new(1, 0, 0, 22),
					Text = sanitizedItem, TextColor3 = pal.text,
					Font = cfg.font, TextSize = cfg.textSize,
					AutoButtonColor = false, BorderSizePixel = 0,
					LayoutOrder = idx, ZIndex = 13,
				}) :: TextButton
				bindHover(windowMaid, opt, pal.elevated, pal.controlHov, pal.controlAct)

				windowMaid:Add(opt.MouseButton1Click:Connect(function()
					if destroying then return end
					sel = item
					face.Text = `{sel}  ▾`
					closeDropdown()
					setFlag(flag, sel)
					safeCall(cb, sel)
				end))
			end

			windowMaid:Add(face.MouseButton1Click:Connect(function()
				if destroying then return end
				if dropped then
					closeDropdown()
				else
					dropped = true
					fo._items += dh / cfg.rowHeight
					tween(row, { Size = UDim2.new(1, 0, 0, cfg.rowHeight + dh) }, 0.18)
					tween(dropWrap, { Size = UDim2.new(0.62, -2, 0, dh) }, 0.18)
					recalc()
				end
			end))

			local api = {} :: ElementAPI<string>
			function api:Set(v: string)
				sel = v
				face.Text = `{v}  ▾`
				setFlag(flag, sel)
				safeCall(cb, sel)
			end
			function api:Get(): string
				return sel
			end
			setFlag(flag, sel)
			return api
		end

		function fo:Bind(opts: BindOpts): ElementAPI<Enum.KeyCode>
			local label = opts.name or opts.text or "Keybind"
			local lo = nxt()
			local key: Enum.KeyCode = opts.default or Enum.KeyCode.E
			local cb = opts.callback or opts.cb
			local flag: string? = opts.flag
			local listening = false

			local row, ctrl = baseRow(container, label, lo)

			local kface = create("TextButton", {
				Parent = ctrl, BackgroundColor3 = pal.control,
				Position = UDim2.new(0, 6, 0.5, -8),
				Size = UDim2.new(0, 60, 0, 16),
				Text = `[{key.Name}]`, TextColor3 = pal.accent,
				Font = cfg.mono, TextSize = 12,
				AutoButtonColor = false, BorderSizePixel = 0,
			}) :: TextButton
			addCorner(kface, 3)
			bindHover(windowMaid, kface, pal.control, pal.controlHov)

			local blacklist = table.freeze({
				Enum.KeyCode.Unknown, Enum.KeyCode.Escape,
				Enum.KeyCode.Backspace, Enum.KeyCode.Return,
			})

			windowMaid:Add(kface.MouseButton1Click:Connect(function()
				if destroying or listening then return end
				listening = true
				kface.Text = "[...]"
				tween(kface, { TextColor3 = pal.warn }, 0.1)

				local conn: Connection
				conn = UserInputService.InputBegan:Connect(function(i)
					if i.UserInputType ~= Enum.UserInputType.Keyboard then return end
					if table.find(blacklist, i.KeyCode) then return end

					key = i.KeyCode
					kface.Text = `[{key.Name}]`
					tween(kface, { TextColor3 = pal.accent }, 0.1)
					listening = false
					setFlag(flag, key)
					conn:Disconnect()
				end)
				windowMaid:Add(conn)
			end))

			windowMaid:Add(UserInputService.InputBegan:Connect(function(i, gpe)
				if gpe or listening or destroying then return end
				if i.KeyCode == key then safeCall(cb, key) end
			end))

			local api = {} :: ElementAPI<Enum.KeyCode>
			function api:Set(k: Enum.KeyCode)
				key = k
				kface.Text = `[{k.Name}]`
				setFlag(flag, k)
			end
			function api:Get(): Enum.KeyCode
				return key
			end
			setFlag(flag, key)
			return api
		end

