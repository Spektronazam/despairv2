local function createSlider(parent, opts)
    opts = opts or {}
    local text     = opts.Text or "Slider"
    local default  = opts.Default or 0
    local min      = opts.Min or 0
    local max      = opts.Max or 100
    local step     = opts.Step or 1
    local suffix   = opts.Suffix or ""
    local flag     = opts.Flag
    local tooltip  = opts.Tooltip
    local callback = opts.Callback

    local value = math.clamp(default, min, max)

    local frame = Util.create("Frame", {
        Parent = parent,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 32),
    })

    local label = Util.create("TextLabel", {
        Parent = frame,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.55, 0, 0, 16),
        Font = Fonts.Regular,
        Text = text,
        TextColor3 = Theme.TextWhite,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local valBox = Util.create("TextBox", {
        Parent = frame,
        BackgroundColor3 = Theme.ItemBg,
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
        Position = UDim2.new(0.55, 0, 0, 0),
        Size = UDim2.new(0.45, 0, 0, 16),
        Font = Fonts.Mono,
        Text = tostring(value) .. suffix,
        TextColor3 = Theme.TextGray,
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Right,
        ClearTextOnFocus = true,
    })
    Util.corner(valBox, 2)

    local bar = Util.create("Frame", {
        Parent = frame,
        BackgroundColor3 = Theme.ItemBg,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 22),
        Size = UDim2.new(1, 0, 0, 5),
    })
    Util.corner(bar, 3)

    local fillScale = (value - min) / (max - min)
    local fill = Util.create("Frame", {
        Parent = bar,
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Size = UDim2.new(fillScale, 0, 1, 0),
    })
    Util.corner(fill, 3)

    local knob = Util.create("Frame", {
        Parent = fill,
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 8, 0, 12),
    })
    Util.corner(knob, 3)

    local function setValue(v, skipCallback)
        v = math.clamp(v, min, max)
        if step >= 1 then
            v = math.floor(v / step + 0.5) * step
        else
            v = math.floor(v / step + 0.5) * step
            v = tonumber(string.format("%.2f", v))
        end
        value = v
        local scale = (value - min) / (max - min)
        fill.Size = UDim2.new(scale, 0, 1, 0)
        valBox.Text = tostring(value) .. suffix
        if not skipCallback and callback then
            task.spawn(callback, value)
        end
    end

    -- Slider drag
    local sliding = false

    local hitArea = Util.create("TextButton", {
        Parent = bar,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 12),
        Position = UDim2.new(0, 0, 0, -6),
        Text = "",
        ZIndex = 5,
        AutoButtonColor = false,
    })

    local function updateFromInput(input)
        local rel = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        local v = min + (max - min) * rel
        setValue(v)
    end

    hitArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true
            updateFromInput(input)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromInput(input)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)

    -- Manual text input
    valBox.FocusLost:Connect(function(enterPressed)
        local num = tonumber(valBox.Text:gsub(suffix, ""):gsub("[^%d%.%-]", ""))
        if num then
            setValue(num)
        else
            valBox.Text = tostring(value) .. suffix
        end
    end)

    -- Scroll wheel support
    hitArea.MouseEnter:Connect(function()
        hitArea._hover = true
    end)
    hitArea.MouseLeave:Connect(function()
        hitArea._hover = false
    end)

    UIS.InputBegan:Connect(function(input)
        if hitArea._hover then
            if input.UserInputType == Enum.UserInputType.MouseWheel then
                -- no direct scroll delta in InputBegan, use InputChanged
            end
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if hitArea._hover and input.UserInputType == Enum.UserInputType.MouseWheel then
            local dir = input.Position.Z > 0 and 1 or -1
            setValue(value + step * dir)
        end
    end)

    if tooltip then
        Tooltip:Bind(hitArea, tooltip)
    end

    if flag then
        Config:RegisterFlag(flag, function() return value end, function(val)
            setValue(val, true)
        end)
    end

    return {
        Frame = frame,
        SetValue = setValue,
        GetValue = function() return value end,
    }
end

