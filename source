local Config = { _flags = {}, _profile = "default" }

function Config:_ensureFolders()
    local ok = pcall(function()
        if not isfolder(CFG_ROOT) then makefolder(CFG_ROOT) end
        if not isfolder(CFG_PROFILES) then makefolder(CFG_PROFILES) end
    end)
    return ok
end

function Config:_path(p) return CFG_PROFILES.."/"..(p or self._profile)..".json" end

function Config:Save(p)
    if not self:_ensureFolders() then return false end
    local data = {}
    for flag, fns in pairs(self._flags) do
        local ok, val = pcall(fns.get)
        if ok then
            if typeof(val) == "Color3" then
                data[flag] = {_t="c3", r=val.R, g=val.G, b=val.B}
            elseif typeof(val) == "EnumItem" then
                data[flag] = {_t="enum", e=tostring(val.EnumType), n=val.Name}
            else
                data[flag] = val
            end
        end
    end
    local ok, json = pcall(HTTP.JSONEncode, HTTP, data)
    if not ok then return false end
    local ok2 = pcall(writefile, self:_path(p), json)
    return ok2
end

function Config:Load(p)
    if not self:_ensureFolders() then return false end
    local ok, exists = pcall(isfile, self:_path(p))
    if not ok or not exists then return false end
    local ok2, raw = pcall(readfile, self:_path(p))
    if not ok2 then return false end
    local ok3, data = pcall(HTTP.JSONDecode, HTTP, raw)
    if not ok3 or type(data) ~= "table" then return false end
    for flag, val in pairs(data) do
        if type(val)=="table" then
            if val._t=="c3" then val = Color3.new(val.r, val.g, val.b)
            elseif val._t=="enum" then pcall(function() val = Enum[val.e][val.n] end) end
        end
        if self._flags[flag] then pcall(self._flags[flag].set, val) end
    end
    self._profile = p or self._profile
    return true
end

function Config:ListProfiles()
    local profiles = {}
    pcall(function()
        if isfolder(CFG_PROFILES) then
            for _,f in ipairs(listfiles(CFG_PROFILES)) do
                local n = f:match("([^/\\]+)%.json$")
                if n then table.insert(profiles, n) end
            end
        end
    end)
    return profiles
end

function Config:DeleteProfile(p) pcall(function() if isfile(self:_path(p)) then delfile(self:_path(p)) end end) end
function Config:Flag(name, get, set) self._flags[name] = {get=get, set=set} end

