----------------------------------------------------------------
-- WIDGET: TOGGLE
----------------------------------------------------------------
local function wToggle(parent, opts)
    opts = opts or {}
    local text, default, flag, cb, indent = opts.Text or "Toggle", opts.Default or false, opts.Flag, opts.Callback, opts.Indent or 0
    local colorPick, hasGear = opts.Color, opts.Gear
    local state = default

    local f = U.new("Frame", { Parent = parent, BackgroundColor3 = T.Panel, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20) })

    -- Animated switch (pill shape)
    local track = U.new("Frame", {
        Parent = f, BackgroundColor3 = state and T.Accent or T.Item, BorderSizePixel = 0,
        Position = UDim2.new(0, indent, 0.5, -7), Size = UDim2.new(0, 28, 0, 14),
    })
    U.corner(track, 7)
    U.stroke(track, state and T.AccentDim or T.Darker)

    local knob = U.new("Frame", {
        Parent = track, BackgroundColor3 = T.White, BorderSizePixel = 0,
        AnchorPoint = Vector2.new(0, 0.5),
        Position = state and UDim2.new(1, -12, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
        Size = UDim2.new(0, 10, 0, 10),
    })
    U.corner(knob, 5)

    local lbl = U.new("TextLabel", {
        Parent = f, BackgroundTransparency = 1,
        Position = UDim2.new(0, indent + 36, 0, 0), Size = UDim2.new(1, -(indent + 36), 1, 0),
        Font = F.Reg, Text = text, TextColor3 = state and T.White or T.Gray, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left,
    })

    local rOff = 0

    -- Color swatch
    local colorState, colorFrame
    if colorPick then
        colorState = colorPick
        colorFrame = U.new("TextButton", {
            Parent = f, BackgroundColor3 = colorState, BorderSizePixel = 0,
            Position = UDim2.new(1, -20 - rOff, 0.5, -5), Size = UDim2.new(0, 20, 0, 10),
            Text = "", AutoButtonColor = false,
        })
        U.corner(colorFrame, 3)
        U.stroke(colorFrame, T.Darker)
        rOff += 26

        -- Color picker popup on click
        colorFrame.MouseButton1Click:Connect(function()
            local popup = U.new("Frame", {
                Parent = Screen, BackgroundColor3 = T.Bg, BorderSizePixel = 0,
                Position = UDim2.new(0, Mouse.X - 100, 0, Mouse.Y + 10),
                Size = UDim2.new(0, 200, 0, 195), ZIndex = 80, ClipsDescendants = true,
            })
            U.corner(popup, 8)
            U.stroke(popup, T.Line)

            -- Open animation
            popup.BackgroundTransparency = 1
            U.tween(popup, { BackgroundTransparency = 0 }, 0.2, Enum.EasingStyle.Quint)

            local h, s, v = U.rgbToHsv(colorState)

            local sv = U.new("ImageButton", {
                Parent = popup, BackgroundColor3 = Color3.fromHSV(h,1,1), BorderSizePixel = 0,
                Position = UDim2.new(0,10,0,10), Size = UDim2.new(0,150,0,150), ZIndex = 81, AutoButtonColor = false, Image = "",
            })
            U.corner(sv, 4)

            U.new("UIGradient", {
                Parent = sv,
                Color = ColorSequence.new(Color3.new(1,1,1), Color3.new(1,1,1)),
                Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1) }),
            })

            local blackOv = U.new("Frame", {
                Parent = sv, BackgroundColor3 = Color3.new(0,0,0), BorderSizePixel = 0, Size = UDim2.new(1,0,1,0), ZIndex = 82,
            })
            U.corner(blackOv, 4)
            U.new("UIGradient", {
                Parent = blackOv,
                Color = ColorSequence.new(Color3.new(0,0,0)),
                Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(1,0) }),
                Rotation = 90,
            })

            local svCur = U.new("Frame", {
                Parent = sv, BackgroundColor3 = T.White, BorderSizePixel = 0,
                AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(s, 0, 1-v, 0),
                Size = UDim2.new(0, 10, 0, 10), ZIndex = 84,
            })
            U.corner(svCur, 5)
            U.stroke(svCur, Color3.new(0,0,0), 2)

            local hueBar = U.new("ImageButton", {
                Parent = popup, BackgroundColor3 = Color3.new(1,1,1), BorderSizePixel = 0,
                Position = UDim2.new(0,170,0,10), Size = UDim2.new(0,18,0,150), ZIndex = 81, AutoButtonColor = false, Image = "",
            })
            U.corner(hueBar, 4)

            local hueKP = {}
            for i = 0, 6 do table.insert(hueKP, ColorSequenceKeypoint.new(i/6, Color3.fromHSV(i/6,1,1))) end
            U.new("UIGradient", { Parent = hueBar, Color = ColorSequence.new(hueKP), Rotation = 90 })

            local hueCur = U.new("Frame", {
                Parent = hueBar, BackgroundColor3 = T.White, BorderSizePixel = 0,
                AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(0.5, 0, h, 0),
                Size = UDim2.new(1, 4, 0, 4), ZIndex = 83,
            })
            U.corner(hueCur, 2)
            U.stroke(hueCur, Color3.new(0,0,0))

            -- Preview
            local preview = U.new("Frame", {
                Parent = popup, BackgroundColor3 = colorState, BorderSizePixel = 0,
                Position = UDim2.new(0, 10, 0, 168), Size = UDim2.new(1, -20, 0, 18), ZIndex = 81,
            })
            U.corner(preview, 3)

            local function upd()
                local c = U.hsvToRgb(h, s, v)
                colorState = c
                colorFrame.BackgroundColor3 = c
                sv.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                svCur.Position = UDim2.new(s, 0, 1 - v, 0)
                hueCur.Position = UDim2.new(0.5, 0, h, 0)
                preview.BackgroundColor3 = c
            end

            local dragSV, dragH = false, false
            sv.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragSV = true
                    s = math.clamp((inp.Position.X - sv.AbsolutePosition.X)/sv.AbsoluteSize.X, 0, 1)
                    v = 1 - math.clamp((inp.Position.Y - sv.AbsolutePosition.Y)/sv.AbsoluteSize.Y, 0, 1)
                    upd()
                end
            end)
            hueBar.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragH = true
                    h = math.clamp((inp.Position.Y - hueBar.AbsolutePosition.Y)/hueBar.AbsoluteSize.Y, 0, 1)
                    upd()
                end
            end)
            local moveConn = UIS.InputChanged:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseMovement then
                    if dragSV then
                        s = math.clamp((inp.Position.X - sv.AbsolutePosition.X)/sv.AbsoluteSize.X, 0, 1)
                        v = 1 - math.clamp((inp.Position.Y - sv.AbsolutePosition.Y)/sv.AbsoluteSize.Y, 0, 1)
                        upd()
                    end
                    if dragH then
                        h = math.clamp((inp.Position.Y - hueBar.AbsolutePosition.Y)/hueBar.AbsoluteSize.Y, 0, 1)
                        upd()
                    end
                end
            end)
            local endConn = UIS.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragSV = false; dragH = false end
            end)

            -- Click outside to close
            task.delay(0.15, function()
                local outsideConn
                outsideConn = UIS.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        task.defer(function()
                            if popup and popup.Parent then
                                local mp = UIS:GetMouseLocation()
                                local ap, as = popup.AbsolutePosition, popup.AbsoluteSize
                                if mp.X < ap.X or mp.X > ap.X+as.X or mp.Y < ap.Y or mp.Y > ap.Y+as.Y then
                                    local tw = U.tween(popup, { BackgroundTransparency = 1, Size = UDim2.new(0, 200, 0, 0) }, 0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
                                    tw.Completed:Wait()
                                    popup:Destroy()
                                    moveConn:Disconnect()
                                    endConn:Disconnect()
                                    outsideConn:Disconnect()
                                end
                            else
                                outsideConn:Disconnect()
                            end
                        end)
                    end
                end)
            end)
        end)
    end

    if hasGear then
        U.new("TextLabel", {
            Parent = f, BackgroundTransparency = 1,
            Position = UDim2.new(1, -14 - rOff, 0.5, -7), Size = UDim2.new(0, 14, 0, 14),
            Font = F.Reg, Text = "⚙", TextColor3 = T.Dark, TextSize = 12,
        })
        rOff += 18
    end

    -- Hit area
    local hit = U.new("TextButton", {
        Parent = f, BackgroundTransparency = 1,
        Size = UDim2.new(0, indent + 36 + 150, 1, 0), Text = "", AutoButtonColor = false, ZIndex = 5,
    })

    local function setState(v, skip)
        state = v
        U.tween(track, { BackgroundColor3 = state and T.Accent or T.Item }, FAST, FAST_STYLE)
        local stroke = track:FindFirstChildOfClass("UIStroke")
        if stroke then U.tweenFast(stroke, { Color = state and T.AccentDim or T.Darker }) end
        U.tween(knob, { Position = state and UDim2.new(1, -12, 0.5, 0) or UDim2.new(0, 2, 0.5, 0) }, 0.25, Enum.EasingStyle.Back)
        U.tweenFast(lbl, { TextColor3 = state and T.White or T.Gray })
        if not skip and cb then task.spawn(cb, state) end
    end

    hit.MouseButton1Click:Connect(function()
        setState(not state)
        -- Knob bounce
        local bounce = state and UDim2.new(1, -10, 0.5, 0) or UDim2.new(0, 0, 0.5, 0)
        U.tween(knob, { Position = bounce }, 0.08, Enum.EasingStyle.Quad)
        task.delay(0.08, function()
            U.tween(knob, { Position = state and UDim2.new(1, -12, 0.5, 0) or UDim2.new(0, 2, 0.5, 0) }, 0.15, Enum.EasingStyle.Back)
        end)
    end)

    hit.MouseEnter:Connect(function() U.tweenFast(f, { BackgroundTransparency = 0.85 }) end)
    hit.MouseLeave:Connect(function() U.tweenFast(f, { BackgroundTransparency = 1 }) end)

    if flag then
        Config:Flag(flag, function() return state end, function(v) setState(v, true) end)
        if colorPick then
            Config:Flag(flag.."_color", function() return colorState end, function(v) colorState = v; if colorFrame then colorFrame.BackgroundColor3 = v end end)
        end
    end

    return { Frame = f, Set = setState, Get = function() return state end }
end

----------------------------------------------------------------
-- WIDGET: SLIDER
----------------------------------------------------------------
local function wSlider(parent, opts)
    opts = opts or {}
    local text, default, mn, mx, step = opts.Text or "Slider", opts.Default or 0, opts.Min or 0, opts.Max or 100, opts.Step or 1
    local suffix, flag, cb = opts.Suffix or "", opts.Flag, opts.Callback
    local value = math.clamp(default, mn, mx)

    local f = U.new("Frame", { Parent = parent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 34) })

    U.new("TextLabel", {
        Parent = f, BackgroundTransparency = 1, Size = UDim2.new(0.55, 0, 0, 16),
        Font = F.Reg, Text = text, TextColor3 = T.White, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left,
    })

    local valBox = U.new("TextBox", {
        Parent = f, BackgroundColor3 = T.Item, BackgroundTransparency = 0.3, BorderSizePixel = 0,
        Position = UDim2.new(0.55, 0, 0, 0), Size = UDim2.new(0.45, 0, 0, 16),
        Font = F.Mono, Text = tostring(value)..suffix, TextColor3 = T.Gray, TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Right, ClearTextOnFocus = true,
    })
    U.corner(valBox, 3)

    local bar = U.new("Frame", { Parent = f, BackgroundColor3 = T.Item, BorderSizePixel = 0, Position = UDim2.new(0,0,0,22), Size = UDim2.new(1,0,0,6) })
    U.corner(bar, 3)

    local scale = (value - mn) / (mx - mn)
    local fill = U.new("Frame", { Parent = bar, BackgroundColor3 = T.Accent, BorderSizePixel = 0, Size = UDim2.new(scale, 0, 1, 0) })
    U.corner(fill, 3)

    -- Glow effect on fill
    U.new("Frame", {
        Parent = fill, BackgroundColor3 = T.AccentGlow, BackgroundTransparency = 0.7, BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
    })
    U.corner(fill:GetChildren()[#fill:GetChildren()], 3)

    local kb = U.new("Frame", {
        Parent = fill, BackgroundColor3 = T.White, BorderSizePixel = 0,
        AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 10, 0, 14),
    })
    U.corner(kb, 4)

    -- Shadow on knob
    U.new("Frame", {
        Parent = kb, BackgroundColor3 = T.Shadow, BackgroundTransparency = 0.7, BorderSizePixel = 0,
        AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0.5, 1, 0.5, 1),
        Size = UDim2.new(1, 2, 1, 2), ZIndex = -1,
    })
    U.corner(kb:GetChildren()[#kb:GetChildren()], 4)

    local function setValue(v, skip)
        v = math.clamp(v, mn, mx)
        if step >= 1 then v = math.floor(v/step+0.5)*step else v = tonumber(string.format("%.2f", math.floor(v/step+0.5)*step)) end
        value = v
        local sc = (value - mn) / (mx - mn)
        U.tweenFast(fill, { Size = UDim2.new(sc, 0, 1, 0) })
        valBox.Text = tostring(value)..suffix
        if not skip and cb then task.spawn(cb, value) end
    end

    local sliding = false
    local hitArea = U.new("TextButton", {
        Parent = bar, BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 16), Position = UDim2.new(0, 0, 0, -8),
        Text = "", ZIndex = 5, AutoButtonColor = false,
    })

    local function fromInput(inp)
        local rel = math.clamp((inp.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        setValue(mn + (mx - mn) * rel)
    end

    hitArea.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true; fromInput(inp)
            -- Knob scale up
            U.tween(kb, { Size = UDim2.new(0, 12, 0, 16) }, FAST, FAST_STYLE)
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then fromInput(inp) end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
            U.tween(kb, { Size = UDim2.new(0, 10, 0, 14) }, FAST, FAST_STYLE)
        end
    end)

    -- Scroll wheel
    hitArea._h = false
    hitArea.MouseEnter:Connect(function() hitArea._h = true end)
    hitArea.MouseLeave:Connect(function() hitArea._h = false end)
    UIS.InputChanged:Connect(function(inp)
        if hitArea._h and inp.UserInputType == Enum.UserInputType.MouseWheel then
            setValue(value + step * (inp.Position.Z > 0 and 1 or -1))
        end
    end)

    valBox.FocusLost:Connect(function()
        local n = tonumber(valBox.Text:gsub(suffix,""):gsub("[^%d%.%-]",""))
        if n then setValue(n) else valBox.Text = tostring(value)..suffix end
    end)

    if flag then Config:Flag(flag, function() return value end, function(v) setValue(v, true) end) end
    return { Frame = f, Set = setValue, Get = function() return value end }
end

----------------------------------------------------------------
-- WIDGET: DROPDOWN
----------------------------------------------------------------
local function wDropdown(parent, opts)
    opts = opts or {}
    local text, options, default, multi = opts.Text or "Dropdown", opts.Options or {}, opts.Default, opts.Multi or false
    local flag, cb = opts.Flag, opts.Callback
    local selected = multi and (type(default)=="table" and default or {}) or (default or (options[1] or ""))
    local opened = false

    local f = U.new("Frame", { Parent = parent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 40), ClipsDescendants = false })

    U.new("TextLabel", {
        Parent = f, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 16),
        Font = F.Reg, Text = text, TextColor3 = T.White, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left,
    })

    local dropBtn = U.new("TextButton", {
        Parent = f, BackgroundColor3 = T.Item, BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 18), Size = UDim2.new(1, 0, 0, 22),
        Text = "", AutoButtonColor = false,
    })
    U.corner(dropBtn, 4)
    U.stroke(dropBtn, T.Darker)

    local function dispText()
        if multi then return #selected == 0 and "None" or table.concat(selected, ", ") end
        return tostring(selected)
    end

    local selLbl = U.new("TextLabel", {
        Parent = dropBtn, BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(1, -28, 1, 0),
        Font = F.Reg, Text = dispText(), TextColor3 = T.Gray, TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd,
    })

    local arrow = U.new("TextLabel", {
        Parent = dropBtn, BackgroundTransparency = 1,
        Position = UDim2.new(1, -20, 0, 0), Size = UDim2.new(0, 16, 1, 0),
        Font = F.Reg, Text = "▾", TextColor3 = T.Dark, TextSize = 14, Rotation = 0,
    })

    local optContainer = U.new("Frame", {
        Parent = f, BackgroundColor3 = T.Item, BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 42), Size = UDim2.new(1, 0, 0, 0),
        ClipsDescendants = true, ZIndex = 70, Visible = false,
    })
    U.corner(optContainer, 4)
    U.stroke(optContainer, T.Line)

    local optScroll = U.new("ScrollingFrame", {
        Parent = optContainer, BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0),
        ScrollBarThickness = 2, ScrollBarImageColor3 = T.Darker, BorderSizePixel = 0,
        CanvasSize = UDim2.new(0,0,0,0), ZIndex = 71,
    })
    local optLayout = U.list(optScroll, 1)

    local function refresh()
        for _,c in ipairs(optScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        for i, opt in ipairs(options) do
            local isSel = multi and table.find(selected, opt) or (selected == opt)
            local ob = U.new("TextButton", {
                Parent = optScroll, BackgroundColor3 = isSel and T.AccentDim or T.Item,
                BackgroundTransparency = isSel and 0.5 or 1, BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 24), Text = "", AutoButtonColor = false, LayoutOrder = i, ZIndex = 72,
            })
            U.new("TextLabel", {
                Parent = ob, BackgroundTransparency = 1,
                Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(1, -16, 1, 0),
                Font = F.Reg, Text = opt, TextColor3 = isSel and T.White or T.Gray, TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 72,
            })
            ob.MouseEnter:Connect(function() U.tweenFast(ob, { BackgroundTransparency = 0.3, BackgroundColor3 = T.ItemHover }) end)
            ob.MouseLeave:Connect(function()
                local s2 = multi and table.find(selected, opt) or (selected == opt)
                U.tweenFast(ob, { BackgroundTransparency = s2 and 0.5 or 1, BackgroundColor3 = s2 and T.AccentDim or T.Item })
            end)
            ob.MouseButton1Click:Connect(function()
                if multi then
                    local idx = table.find(selected, opt)
                    if idx then table.remove(selected, idx) else table.insert(selected, opt) end
                    selLbl.Text = dispText(); refresh()
                    if cb then task.spawn(cb, selected) end
                else
                    selected = opt; selLbl.Text = dispText(); refresh()
                    -- Close
                    opened = false
                    U.tween(optContainer, { Size = UDim2.new(1,0,0,0) }, 0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
                    U.tween(arrow, { Rotation = 0 }, 0.2, Enum.EasingStyle.Back)
                    task.delay(0.2, function() if not opened then optContainer.Visible = false end end)
                    f.Size = UDim2.new(1, 0, 0, 40)
                    if cb then task.spawn(cb, selected) end
                end
            end)
        end
        optScroll.CanvasSize = UDim2.new(0, 0, 0, optLayout.AbsoluteContentSize.Y + 4)
    end
    refresh()

    dropBtn.MouseButton1Click:Connect(function()
        opened = not opened
        if opened then
            local h = math.min(#options * 25 + 4, 150)
            optContainer.Visible = true
            U.tween(optContainer, { Size = UDim2.new(1, 0, 0, h) }, 0.25, Enum.EasingStyle.Back)
            U.tween(arrow, { Rotation = 180 }, 0.25, Enum.EasingStyle.Back)
            f.Size = UDim2.new(1, 0, 0, 44 + h)
        else
            U.tween(optContainer, { Size = UDim2.new(1,0,0,0) }, 0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
            U.tween(arrow, { Rotation = 0 }, 0.2, Enum.EasingStyle.Back)
            task.delay(0.2, function() if not opened then optContainer.Visible = false end end)
            f.Size = UDim2.new(1, 0, 0, 40)
        end
    end)

    dropBtn.MouseEnter:Connect(function() U.tweenFast(dropBtn, { BackgroundColor3 = T.ItemHover }) end)
    dropBtn.MouseLeave:Connect(function() U.tweenFast(dropBtn, { BackgroundColor3 = T.Item }) end)

    if flag then Config:Flag(flag, function() return selected end, function(v) selected = v; selLbl.Text = dispText(); refresh() end) end
    return { Frame = f, Get = function() return selected end, SetOptions = function(o) options = o; refresh() end }
end

----------------------------------------------------------------
-- WIDGET: KEYBIND
----------------------------------------------------------------
local function wKeybind(parent, opts)
    opts = opts or {}
    local text, default, flag, cb, mode = opts.Text or "Keybind", opts.Default, opts.Flag, opts.Callback, opts.Mode or "Toggle"
    local bound, listening, active = default, false, false

    local f = U.new("Frame", { Parent = parent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20) })

    U.new("TextLabel", {
        Parent = f, BackgroundTransparency = 1, Size = UDim2.new(0.55, 0, 1, 0),
        Font = F.Reg, Text = text, TextColor3 = T.Gray, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left,
    })

    local btn = U.new("TextButton", {
        Parent = f, BackgroundColor3 = T.Item, BorderSizePixel = 0,
        Position = UDim2.new(0.55, 4, 0.5, -9), Size = UDim2.new(0.45, -4, 0, 18),
        Font = F.Mono, Text = bound and ("[ "..U.keyName(bound).." ]") or "[ — ]",
        TextColor3 = T.Dark, TextSize = 10, AutoButtonColor = false,
    })
    U.corner(btn, 4)

    btn.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true; btn.Text = "[ ... ]"; U.tweenFast(btn, { TextColor3 = T.Accent })
        local conn; conn = UIS.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Keyboard then
                if inp.KeyCode == Enum.KeyCode.Escape then bound = nil; btn.Text = "[ — ]"
                else bound = inp.KeyCode; btn.Text = "[ "..U.keyName(bound).." ]" end
                U.tweenFast(btn, { TextColor3 = T.Dark }); listening = false; conn:Disconnect()
            end
        end)
    end)

    btn.MouseButton2Click:Connect(function() bound = nil; btn.Text = "[ — ]" end)

    UIS.InputBegan:Connect(function(inp, proc)
        if proc or listening then return end
        if bound and inp.KeyCode == bound then
            if mode == "Toggle" then active = not active; if cb then task.spawn(cb, active) end
            elseif mode == "Hold" then active = true; if cb then task.spawn(cb, true) end end
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if bound and inp.KeyCode == bound and mode == "Hold" then active = false; if cb then task.spawn(cb, false) end end
    end)

    if flag then Config:Flag(flag, function() return bound and bound.Name or nil end, function(v) if v then pcall(function() bound = Enum.KeyCode[v]; btn.Text = "[ "..U.keyName(bound).." ]" end) else bound = nil; btn.Text = "[ — ]" end end) end
    return { Frame = f, GetKey = function() return bound end }
end

----------------------------------------------------------------
-- WIDGET: BUTTON
----------------------------------------------------------------
local function wButton(parent, opts)
    opts = opts or {}
    local text, cb, confirm = opts.Text or "Button", opts.Callback, opts.Confirm or false

    local f = U.new("Frame", { Parent = parent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 26) })

    local btn = U.new("TextButton", {
        Parent = f, BackgroundColor3 = T.Item, BorderSizePixel = 0, Size = UDim2.new(1, 0, 1, 0),
        Font = F.Semi, Text = text, TextColor3 = T.White, TextSize = 11, AutoButtonColor = false, ClipsDescendants = true,
    })
    U.corner(btn, 5)
    U.stroke(btn, T.Darker)

    local confirming = false
    btn.MouseButton1Click:Connect(function()
        U.ripple(btn, Mouse.X - btn.AbsolutePosition.X, Mouse.Y - btn.AbsolutePosition.Y)
        if confirm and not confirming then
            confirming = true; btn.Text = "Confirm?"; btn.TextColor3 = T.Yellow
            task.delay(2.5, function() if confirming then confirming = false; btn.Text = text; btn.TextColor3 = T.White end end)
            return
        end
        confirming = false; btn.Text = text; btn.TextColor3 = T.White
        if cb then task.spawn(cb) end
    end)

    btn.MouseEnter:Connect(function() U.tweenFast(btn, { BackgroundColor3 = T.ItemHover }) end)
    btn.MouseLeave:Connect(function() U.tweenFast(btn, { BackgroundColor3 = T.Item }) end)

    return { Frame = f }
end

----------------------------------------------------------------
-- WIDGET: TEXT INPUT
----------------------------------------------------------------
local function wInput(parent, opts)
    opts = opts or {}
    local text, default, ph, flag, cb = opts.Text or "Input", opts.Default or "", opts.Placeholder or "...", opts.Flag, opts.Callback
    local value = default

    local f = U.new("Frame", { Parent = parent, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 40) })
    U.new("TextLabel", { Parent = f, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,16), Font = F.Reg, Text = text, TextColor3 = T.White, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left })

    local box = U.new("TextBox", {
        Parent = f, BackgroundColor3 = T.Item, BorderSizePixel = 0,
        Position = UDim2.new(0,0,0,18), Size = UDim2.new(1,0,0,22),
        Font = F.Mono, PlaceholderText = ph, PlaceholderColor3 = T.Dark,
        Text = value, TextColor3 = T.White, TextSize = 11, ClearTextOnFocus = false, TextXAlignment = Enum.TextXAlignment.Left,
    })
    U.corner(box, 4)
    local boxStroke = U.stroke(box, T.Darker)
    U.pad(box, 8, 8, 0, 0)

    box:GetPropertyChangedSignal("Text"):Connect(function() value = box.Text end)
    box.FocusLost:Connect(function() if cb then task.spawn(cb, value) end end)
    box.Focused:Connect(function() U.tweenFast(boxStroke, { Color = T.Accent }) end)
    box.FocusLost:Connect(function() U.tweenFast(boxStroke, { Color = T.Darker }) end)

    if flag then Config:Flag(flag, function() return value end, function(v) value = tostring(v); box.Text = value end) end
    return { Frame = f, Get = function() return value end, Set = function(v) value = v; box.Text = v end }
end

