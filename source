-- UTILITY MODULE
----------------------------------------------------------------
local Util = {}

function Util.create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then
            inst[k] = v
        end
    end
    if props.Parent then
        inst.Parent = props.Parent
    end
    return inst
end

function Util.tween(obj, props, duration, style, dir)
    local ti = TweenInfo.new(duration or ANIM_SPEED, style or ANIM_STYLE, dir or ANIM_DIR)
    local t = TweenService:Create(obj, ti, props)
    t:Play()
    return t
end

function Util.line(parent, pos, size)
    return Util.create("Frame", {
        Parent = parent,
        BackgroundColor3 = Theme.LineColor,
        BorderSizePixel = 0,
        Position = pos,
        Size = size,
    })
end

function Util.corner(parent, radius)
    return Util.create("UICorner", {
        Parent = parent,
        CornerRadius = UDim.new(0, radius or 4),
    })
end

function Util.stroke(parent, color, thickness)
    return Util.create("UIStroke", {
        Parent = parent,
        Color = color or Theme.LineColor,
        Thickness = thickness or 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })
end

function Util.padding(parent, l, r, t, b)
    return Util.create("UIPadding", {
        Parent = parent,
        PaddingLeft = UDim.new(0, l or 0),
        PaddingRight = UDim.new(0, r or 0),
        PaddingTop = UDim.new(0, t or 0),
        PaddingBottom = UDim.new(0, b or 0),
    })
end

function Util.listLayout(parent, padding, sortOrder, direction)
    return Util.create("UIListLayout", {
        Parent = parent,
        SortOrder = sortOrder or Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, padding or 6),
        FillDirection = direction or Enum.FillDirection.Vertical,
    })
end

function Util.lerp(a, b, t)
    return a + (b - a) * t
end

function Util.deepCopy(t)
    if type(t) ~= "table" then return t end
    local copy = {}
    for k, v in pairs(t) do
        copy[k] = Util.deepCopy(v)
    end
    return copy
end

function Util.rgbToHSV(color)
    local r, g, b = color.R, color.G, color.B
    local max, min = math.max(r, g, b), math.min(r, g, b)
    local h, s, v = 0, 0, max
    local d = max - min
    s = max == 0 and 0 or d / max
    if max ~= min then
        if max == r then
            h = (g - b) / d + (g < b and 6 or 0)
        elseif max == g then
            h = (b - r) / d + 2
        else
            h = (r - g) / d + 4
        end
        h = h / 6
    end
    return h, s, v
end

function Util.hsvToRGB(h, s, v)
    return Color3.fromHSV(math.clamp(h, 0, 1), math.clamp(s, 0, 1), math.clamp(v, 0, 1))
end

function Util.keyName(keyCode)
    local name = keyCode.Name
    local map = {
        LeftShift = "LShift", RightShift = "RShift",
        LeftControl = "LCtrl", RightControl = "RCtrl",
        LeftAlt = "LAlt", RightAlt = "RAlt",
        BackSlash = "\\", Slash = "/",
        Backquote = "`", LeftBracket = "[", RightBracket = "]",
        Semicolon = ";", Quote = "'", Comma = ",", Period = ".",
        Minus = "-", Equals = "=", Space = "Space",
        Backspace = "BkSp", Delete = "Del",
        Insert = "Ins", Home = "Home", End = "End",
        PageUp = "PgUp", PageDown = "PgDn",
        CapsLock = "Caps", Tab = "Tab",
    }
    return map[name] or name
end

function Util.formatColor(c)
    return string.format("%d, %d, %d", math.floor(c.R * 255), math.floor(c.G * 255), math.floor(c.B * 255))
end

function Util.parseColor(s)
    local r, g, b = s:match("(%d+)%s*,%s*(%d+)%s*,%s*(%d+)")
    if r then
        return Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b))
    end
    return nil
end

