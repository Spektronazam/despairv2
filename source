local function createButton(parent, opts)
    opts = opts or {}
    local text     = opts.Text or "Button"
    local callback = opts.Callback
    local confirm  = opts.Confirm or false

    local frame = Util.create("Frame", {
        Parent = parent,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 24),
    })

    local btn = Util.create("TextButton", {
        Parent = frame,
        BackgroundColor3 = Theme.ItemBg,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        Font = Fonts.SemiBold,
        Text = text,
        TextColor3 = Theme.TextWhite,
        TextSize = 11,
        AutoButtonColor = false,
    })
    Util.corner(btn, 3)
    Util.stroke(btn, Theme.LineDark)

    local confirming = false

    btn.MouseButton1Click:Connect(function()
        if confirm and not confirming then
            confirming = true
            btn.Text = "Click again to confirm"
            btn.TextColor3 = Theme.Warning
            task.delay(3, function()
                if confirming then
                    confirming = false
                    btn.Text = text
                    btn.TextColor3 = Theme.TextWhite
                end
            end)
            return
        end
        confirming = false
        btn.Text = text
        btn.TextColor3 = Theme.TextWhite

        -- Flash effect
        btn.BackgroundColor3 = Theme.Accent
        Util.tween(btn, { BackgroundColor3 = Theme.ItemBg }, 0.4)

        if callback then task.spawn(callback) end
    end)

    btn.MouseEnter:Connect(function()
        Util.tween(btn, { BackgroundColor3 = Theme.ItemBgHover }, ANIM_SPEED_FAST)
    end)
    btn.MouseLeave:Connect(function()
        Util.tween(btn, { BackgroundColor3 = Theme.ItemBg }, ANIM_SPEED_FAST)
    end)

    return { Frame = frame }
end

