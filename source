------------------------------ Maid (Connection Tracker) ------------------------------

local function createMaid(): Maid
	local maid: Maid = { _tasks = {} } :: Maid

	function maid:Add(task: CleanupTask): CleanupTask
		table.insert(self._tasks, task)
		return task
	end

	function maid:Cleanup()
		for _, task in self._tasks do
			if typeof(task) == "RBXScriptConnection" then
				(task :: Connection):Disconnect()
			elseif typeof(task) == "Instance" then
				(task :: Instance):Destroy()
			elseif type(task) == "function" then
				(task :: () -> ())()
			end
		end
		table.clear(self._tasks)
	end

	return maid
end

------------------------------ Safe Callback Invocation ------------------------------

local function safeCall<T...>(cb: Callback<T...>?, ...: T...)
	if not cb then return end
	local ok, err = pcall(cb, ...)
	if not ok then
		warn(`[Despair] Callback error: {err}`)
	end
end

------------------------------ Root Resolution (Identity-Aware) ------------------------------

local root: Instance do
	local prevIdentity: number? = nil
	if getthreadidentity and setthreadidentity then
		prevIdentity = getthreadidentity()
		if prevIdentity and prevIdentity < 3 then
			setthreadidentity(8)
		end
	end

	if gethui then
		root = gethui()
	else
		local ok, coreGui = pcall(game.GetService, game, "CoreGui")
		root = if ok and coreGui then coreGui else Players.LocalPlayer:WaitForChild("PlayerGui")
	end

	if prevIdentity and setthreadidentity and prevIdentity < 3 then
		setthreadidentity(prevIdentity)
	end
end

