function U.ripple(parent, posX, posY, color)
    local circle = U.new("Frame", {
        Parent = parent,
        BackgroundColor3 = color or T.AccentGlow,
        BackgroundTransparency = 0.6,
        AnchorPoint = Vector2.new(0.5, 0.5),
