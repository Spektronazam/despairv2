        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Visible = isDefault,
    })

    bottomTabs[name] = {
        container = container, iconLbl = iconLbl,
        textLbl = textLbl, indicator = indicator, page = page,
    }

    container.MouseButton1Click:Connect(function()
        switchBottomTab(name)
    end)

    container.MouseEnter:Connect(function()
        if activeBottomTab ~= name then
            Util.tween(iconLbl, { TextColor3 = Theme.TextGray }, ANIM_SPEED_FAST)
