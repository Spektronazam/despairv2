------------------------------ Notifications ------------------------------

function Despair:Notify(opts: { msg: string?, text: string?, duration: number?, type: string? })
	local msg = sanitizeString(opts.msg or opts.text or "", 500)
	local dur = math.clamp(opts.duration or 3.5, 0.5, 30)
	local ntype = opts.type or "info"

	local sg = root:FindFirstChild(SALT)
	if not sg then return end

	if not notifHolder or not notifHolder.Parent then
		notifHolder = create("Frame", {
			Parent = sg, Name = "_nf", BackgroundTransparency = 1,
			AnchorPoint = Vector2.new(1, 1), Position = UDim2.new(1, -16, 1, -16),
			Size = UDim2.new(0, 260, 1, -32),
		}) :: Frame
		create("UIListLayout", {
			Parent = notifHolder, SortOrder = Enum.SortOrder.LayoutOrder,
			VerticalAlignment = Enum.VerticalAlignment.Bottom, Padding = UDim.new(0, 6),
		})
	end

	if notifCount >= cfg.maxNotifications then return end
	notifCount += 1

	local colorMap = table.freeze({
		info = pal.accent, success = pal.success,
		warn = pal.warn, error = pal.danger,
	})
	local nc = colorMap[ntype] or pal.accent

	local nf = create("Frame", {
		Parent = notifHolder, BackgroundColor3 = pal.surface,
		Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundTransparency = 1,
	}) :: Frame
	addCorner(nf, 6)
	local nfStroke = addStroke(nf, nc, 1)

	create("Frame", {
		Parent = nf, BackgroundColor3 = nc,
		Size = UDim2.new(0, 3, 1, 0), BorderSizePixel = 0,
	})

	create("TextLabel", {
		Parent = nf, BackgroundTransparency = 1,
		Position = UDim2.new(0, 14, 0, 8), Size = UDim2.new(1, -22, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y, Text = msg,
		TextColor3 = pal.text, Font = cfg.font, TextSize = 13,
		TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left,
	})
	create("UIPadding", { Parent = nf, PaddingBottom = UDim.new(0, 8) })

	tween(nf, { BackgroundTransparency = 0 }, 0.25)

	task.delay(dur, function()
		if not nf or not nf.Parent then
			notifCount -= 1
			return
		end
		tween(nf, { BackgroundTransparency = 1 }, 0.35)
		tween(nfStroke, { Transparency = 1 }, 0.35)
		task.wait(0.4)
		if nf and nf.Parent then
			nf:Destroy()
		end
		notifCount -= 1
	end)
end

